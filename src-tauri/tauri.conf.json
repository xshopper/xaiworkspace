{
  "$schema": "https://raw.githubusercontent.com/nicedozie4u/tauri/refs/heads/dev/crates/tauri-config-schema/schema.json",
  "productName": "xAI Workspace",
  "version": "0.2.0",
  "identifier": "com.xaiworkspace.desktop",
  "build": {
    "frontendDist": "../src",
    "devUrl": "http://localhost:1420"
  },
  "app": {
    "withGlobalTauri": true,
    "trayIcon": {
      "iconPath": "icons/tray-icon.png",
      "iconAsTemplate": false
    },
    "windows": [
      {
        "title": "xAI Workspace Setup",
        "width": 420,
        "height": 320,
        "resizable": false,
        "center": true,
        "decorations": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src https://router.xaiworkspace.com https://router-test.xaiworkspace.com https://desktop.docker.com http://localhost:*; style-src 'self' 'unsafe-inline'"
    }
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["xaiworkspace"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "msi", "appimage"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
